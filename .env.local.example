# ================================================================
# Bella Curvas — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# NUNCA commite o arquivo .env.local no git!
# ================================================================

# --- Supabase (obrigatório) ---
# Encontre no painel Supabase > Settings > API
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...sua_anon_key...

# ================================================================
# As variáveis abaixo são usadas SOMENTE pelas Edge Functions
# (Supabase Secrets — configure em Settings > Edge Functions > Secrets)
# Não são acessíveis pelo browser.
# ================================================================

# --- Supabase Service Role (somente Edge Functions) ---
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua_service_role_key...

# --- Evolution API (WhatsApp para grupos) ---
# Instale no seu VPS: https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL=https://seu-vps.com:8080
EVOLUTION_API_KEY=sua_chave_secreta
EVOLUTION_INSTANCE_NAME=bella-curvas

# --- MercadoPago (pagamentos — Fase 4) ---
# Obtenha em https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=APP_USR-...ou TEST-...

# --- Resend (emails transacionais — Fase 4) ---
# Crie conta em https://resend.com
RESEND_API_KEY=re_...

# --- Meta / Instagram (redes sociais — Fase 3) ---
# Crie App em https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=seu_token_longa_duracao
INSTAGRAM_USER_ID=seu_instagram_user_id
FACEBOOK_PAGE_ID=sua_page_id
FACEBOOK_ACCESS_TOKEN=seu_page_access_token
